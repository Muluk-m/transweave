# =============================================================================
# Transweave Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].
# Optional variables show their default values.

# --- Database ---

# [REQUIRED for Docker] PostgreSQL connection string.
# Omit entirely for PGlite (zero-config local development).
DATABASE_URL=postgresql://i18n:changeme@localhost:5432/i18n

# PostgreSQL settings (used by Docker Compose only)
POSTGRES_DB=i18n
POSTGRES_USER=i18n
# [REQUIRED] Change this to a strong password!
POSTGRES_PASSWORD=changeme

# --- Authentication ---

# [REQUIRED] Secret key for signing JWT tokens.
# Generate with: openssl rand -base64 64
JWT_SECRET=

# --- Server ---

# Port the backend API listens on (default: 3001)
PORT=3001

# Directory for uploaded files such as screenshots (default: ./uploads)
UPLOAD_DIR=./uploads

# --- Frontend ---

# Backend API URL for server-side rendering inside the Docker network.
# Only relevant when running in Docker Compose.
NEXT_INTERNAL_API_URL=http://server:3001

# Host port to expose the web UI on (Docker Compose only, default: 3000)
WEB_PORT=3000

# --- AI Translation (Optional) ---

# Leave empty to disable AI translation features entirely.
# Supported providers: openai | claude | deepl | google
AI_PROVIDER=
AI_API_KEY=

# --- Development ---

# PGlite data directory (used when DATABASE_URL is not set)
PGLITE_DATA_DIR=./data/pglite
